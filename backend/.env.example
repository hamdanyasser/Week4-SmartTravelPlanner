# Copy this file to backend/.env and fill in the values.
# Day 1 only needs the basics; we will grow this list as features land.

APP_NAME=TripPilot Black
APP_ENV=development
APP_DEBUG=true

# CORS — comma-separated list of frontend origins allowed to call the API.
CORS_ALLOW_ORIGINS=http://localhost:5173

# Database (used from Day 5 onward; safe to leave as-is in dev).
DATABASE_URL=postgresql+asyncpg://trippilot:trippilot@db:5432/trippilot

# LLM keys — added when the agent lands.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
