# Copy this file to backend/.env and fill in the values.
# Fill only the services you want to exercise locally; fallbacks keep the demo safe.

APP_NAME=AtlasBrief
APP_ENV=development
APP_DEBUG=true

# CORS - comma-separated list of frontend origins allowed to call the API.
CORS_ALLOW_ORIGINS=http://localhost:5173

# Local Postgres container. Replace the password in backend/.env for real use.
POSTGRES_USER=trippilot
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=trippilot

# Database for SQLAlchemy persistence and pgvector RAG.
DATABASE_URL=postgresql+asyncpg://trippilot:change-me-local-only@db:5432/trippilot

# RAG embeddings. Deterministic works locally with no network or secrets.
EMBEDDING_PROVIDER=deterministic
EMBEDDING_DIMENSION=384

# Auth. Generate a long random value for real use.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=120

# LLM/model routing. Fallback names are used when provider keys are missing.
CHEAP_MODEL_NAME=deterministic-extractor
STRONG_MODEL_NAME=deterministic-synthesizer
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Live conditions. Disabled by default so local demos are deterministic.
WEATHER_LIVE_ENABLED=false
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEOUT_SECONDS=4

# Discord webhook. Empty means "skip delivery"; failure never breaks the API.
DISCORD_WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=4
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_ENABLED=true

# Keep false for local no-Docker development; run app.db.init_db manually when DB is up.
DATABASE_INIT_ON_STARTUP=false
