# Copy this file to backend/.env and fill in the values.
# Fill only the services you want to exercise locally; fallbacks keep the demo safe.

APP_NAME=AtlasBrief
APP_ENV=development
APP_DEBUG=true

# CORS - comma-separated list of frontend origins allowed to call the API.
CORS_ALLOW_ORIGINS=http://localhost:5173

# Local Postgres container. Replace the password in backend/.env for real use.
POSTGRES_USER=trippilot
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=trippilot

# Database for SQLAlchemy persistence and pgvector RAG.
DATABASE_URL=postgresql+asyncpg://trippilot:change-me-local-only@db:5432/trippilot

# RAG embeddings. Deterministic works locally with no network or secrets.
EMBEDDING_PROVIDER=deterministic
EMBEDDING_DIMENSION=384

# Auth. The codebase ships an obvious development default so the demo runs
# out of the box. PRODUCTION DEPLOYS MUST OVERRIDE THIS — generate >= 32 bytes
# of randomness, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
JWT_SECRET_KEY=dev-only-do-not-use-in-prod-please-rotate-on-deploy
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=120

# LLM/model routing. Fallback names are used when provider keys are missing.
# When ANTHROPIC_API_KEY or OPENAI_API_KEY is set, the strong synthesis step
# calls the real provider and `meta.cost_usd` becomes a real number.
CHEAP_MODEL_NAME=deterministic-extractor
STRONG_MODEL_NAME=deterministic-synthesizer
# Provider preference for each role: auto | anthropic | openai | none.
# `auto` picks Anthropic if its key is set, else OpenAI.
CHEAP_MODEL_PROVIDER=auto
STRONG_MODEL_PROVIDER=auto
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-6
OPENAI_CHEAP_MODEL=gpt-4o-mini
OPENAI_STRONG_MODEL=gpt-4o
LLM_MAX_OUTPUT_TOKENS=600
LLM_REQUEST_TIMEOUT_SECONDS=30

# LangSmith tracing. Empty means "no tracing"; the agent still works fine.
# LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=atlasbrief
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Live conditions. Disabled by default so local demos are deterministic.
WEATHER_LIVE_ENABLED=false
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEOUT_SECONDS=4

# Discord webhook. Empty means "skip delivery"; failure never breaks the API.
DISCORD_WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=4
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_ENABLED=true

# Docker/local DB bootstrap. Startup creates tables and seeds the small RAG corpus
# only when the pgvector table is empty.
DATABASE_INIT_ON_STARTUP=true
RAG_INGEST_ON_STARTUP=true
