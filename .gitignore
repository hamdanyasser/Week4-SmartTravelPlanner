# ML artifacts.
# We commit the canonical model.joblib + results.csv (they are deliverables in
# the brief and the artifact is small). Anything else under ml/ that ends in
# .joblib or .pkl is local-only.
backend/app/ml/**/*.joblib
!backend/app/ml/model.joblib
backend/app/ml/**/*.pkl

# Docker
.docker/
# Local-only docker compose override (alternate host ports for dev machines
# whose default ports are taken by other services).
docker-compose.override.yml

.vercel/
